#!/bin/sh

limit_bytes=$((55 * 1024 * 1024))
empty_tree=$(git hash-object -t tree /dev/null)
failed=0

while read -r local_ref local_sha remote_ref remote_sha
do
  [ -z "$local_sha" ] && continue
  case "$local_sha" in
    0000000000000000000000000000000000000000) continue ;;
  esac

  base_sha=$remote_sha
  case "$remote_sha" in
    ""|0000000000000000000000000000000000000000) base_sha=$empty_tree ;;
  esac

  tmp_file=$(mktemp) || exit 1
  git diff --name-only --diff-filter=AM -z "$base_sha" "$local_sha" > "$tmp_file"

  while IFS= read -r -d '' path
  do
    size=$(git cat-file -s "$local_sha:$path" 2>/dev/null || echo 0)
    if [ "$size" -gt "$limit_bytes" ]; then
      size_mb=$(awk "BEGIN { printf \"%.2f\", $size / 1048576 }")
      echo "Blocked: push contains file over 55 MB: $path (${size_mb} MB)" >&2
      failed=1
    fi
  done < "$tmp_file"

  rm -f "$tmp_file"
done

if [ "$failed" -ne 0 ]; then
  echo "Push cancelled. Remove oversized files from the branch before pushing." >&2
  exit 1
fi
