{
  "name": "deaf-territory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('.next', { recursive: true, force: true })\"",
    "dev": "next dev",
    "dev:clean": "npm run clean && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:load-psgc-xlsx": "tsx scripts/load-psgc-xlsx.ts",
    "db:generate-iloilo-boundaries": "tsx scripts/generate-iloilo-boundaries.ts",
    "db:import-psgc": "tsx scripts/import-psgc.ts",
    "db:import-boundaries": "tsx scripts/import-boundaries.ts",
    "db:build-search-index": "tsx scripts/build-search-index.ts",
    "db:validate-data": "tsx scripts/validate-data.ts",
    "db:prepare": "npm run db:import-psgc && npm run db:import-boundaries && npm run db:build-search-index && npm run db:validate-data"
  },
  "dependencies": {
    "maplibre-gl": "^5.6.2",
    "next": "15.3.8",
    "pg": "^8.13.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "shapefile": "^0.6.6",
    "shpjs": "^6.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "@types/node": "^22",
    "@types/pg": "^8.11.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/shapefile": "^0.6.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "15.3.8",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
}
